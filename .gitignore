# ============================================================================
# MiningNiti .gitignore
# ============================================================================

# ── Environment Files (NEVER commit these) ─────────────────────────────────
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging
backend/.env
frontend/.env.local
# Keep example files
!.env.example
!.env.local.example
!backend/.env.example

# ── Python ─────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
/lib/
/lib64/
backend/lib/
backend/lib64/
venv/
env/
ENV/
.venv/
.Python
pip-log.txt
pip-delete-this-directory.txt

# ── Node / Frontend ─────────────────────────────────────────────────────────
node_modules/
.next/
out/
*.tsbuildinfo
.turbo/
.cache/
.eslintcache

# ── Database Files (NEVER commit these) ────────────────────────────────────
*.db
*.sqlite
*.sqlite3
backend/test.db

# ── Testing ─────────────────────────────────────────────────────────────────
coverage/
.pytest_cache/
pytest-cache-files-*/
*.coverage
coverage.xml
htmlcov/
.tox/
.nox/
.hypothesis/

# ── Build / Distribution ───────────────────────────────────────────────────
dist/
build/
*.egg-info/

# ── IDE ─────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*.swo
*.sublime-project
*.sublime-workspace
*.iml

# ── OS ──────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V500
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Celery ──────────────────────────────────────────────────────────────────
celerybeat-schedule
celerybeat.pid

# ── Uploads (keep structure, not contents) ──────────────────────────────────
backend/uploads/*
!backend/.gitkeep
uploads/*
!uploads/.gitkeep

# ── Local tooling (never commit) ────────────────────────────────────────────
.mimocode/
miningniti-api/

# ── Ad-hoc test scripts (keep them out of repo) ────────────────────────────
backend/test_*.py
backend/check_*.py
backend/verify_*.py
backend/seed_*.py

# ── Misc ────────────────────────────────────────────────────────────────────
.vercel
.netlify
retry_acts.py
