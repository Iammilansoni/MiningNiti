# Backend Environment Variables
# Copy to .env and fill in your values

# =============================================================================
# Database Configuration
# =============================================================================
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
SSL_CERT_PATH=config/prod-ca-2021.crt

# =============================================================================
# AI Configuration - Google Gemini
# =============================================================================
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=models/text-embedding-004

# Cerebras — Free tier: 1M tokens/day, no credit card required
# Get key at: https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_api_key_here

# =============================================================================
# Authentication - Clerk
# =============================================================================
CLERK_JWKS_URL=https://your-app.clerk.accounts.dev/.well-known/jwks.json

# =============================================================================
# Redis (for background jobs)
# =============================================================================
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# Application Settings
# =============================================================================
APP_NAME=MiningNiti
APP_VERSION=2.0.0
ENVIRONMENT=development
DEBUG=true

# =============================================================================
# MLOps — LangSmith Observability (optional, enables tracing)
# =============================================================================
# Set LANGCHAIN_TRACING_V2=true to activate tracing.
# Get your API key at: https://smith.langchain.com/settings
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key_here
LANGCHAIN_PROJECT=miningniti
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# =============================================================================
# Document Processing
# =============================================================================
MAX_FILE_SIZE_MB=50
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# =============================================================================
# API Settings
# =============================================================================
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]
